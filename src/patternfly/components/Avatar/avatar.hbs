<img class="{{pfv}}avatar
  {{~#if avatar--modifier}} {{avatar--modifier}}{{/if}}"
  alt="{{#if avatar--alt}}{{avatar--alt}}{{else}}{{/if}}"
  src="
    {{~#if avatar--src}}{{avatar--src}}
    {{~else}}/assets/images/img_avatar-light.svg{{/if}}"
  {{#if avatar--attribute}}
    {{{avatar--attribute}}}
  {{/if}}>
