{{#if avatar--IsImg}}
  <img class="{{pfv}}avatar
    {{setModifiers
      avatar--IsBordered='pf-m-bordered'
      avatar--IsSmall='pf-m-sm'
      avatar--IsMedium='pf-m-md'
      avatar--IsLarge='pf-m-lg'
      avatar--IsXLarge='pf-m-xl'
      avatar--modifier=avatar--modifier
    }}"
    alt="{{#if avatar--alt}}{{avatar--alt}}{{else}}{{/if}}"
    src="{{ ternary avatar--src avatar--src '/assets/images/img_avatar-light.svg' }}"
    {{#if avatar--attribute}}
      {{{avatar--attribute}}}
    {{/if}}>
{{else}}
  <div class="{{pfv}}avatar
    {{setModifiers
      avatar--IsBordered='pf-m-bordered'
      avatar--IsSmall='pf-m-sm'
      avatar--IsMedium='pf-m-md'
      avatar--IsLarge='pf-m-lg'
      avatar--IsXLarge='pf-m-xl'
      avatar--IsColorful='pf-m-colorful'
      avatar--IsRed='pf-m-red'
      avatar--IsOrangered='pf-m-orangered'
      avatar--IsOrange='pf-m-orange'
      avatar--IsYellow='pf-m-yellow'
      avatar--IsGreen='pf-m-green'
      avatar--IsTeal='pf-m-teal'
      avatar--IsBlue='pf-m-blue'
      avatar--IsPurple='pf-m-purple'
      avatar--IsGray='pf-m-gray'
      avatar--modifier=avatar--modifier
    }}"
    {{#if avatar--attribute}}
      {{{avatar--attribute}}}
    {{/if}}
    role="img"
    {{#if avatar--aria-label}}aria-label="{{avatar--aria-label}}"{{else}}aria-hidden="true"{{/if}}>
    {{#if avatar--initials}}
      <span class="{{pfv}}avatar__initials" aria-hidden="true">{{avatar--initials}}</span>
    {{else if avatar--icon}}
      {{pfIcon avatar--icon}}
    {{else if @partial-block}}
      {{> @partial-block}}
    {{else}}
      <svg aria-hidden="true" data-name="Layer 1" xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="0 0 36 36">
        <path fill="currentColor" d="M17.7,20.1c-3.5,0-6.4-2.9-6.4-6.4s2.9-6.4,6.4-6.4,6.4,2.9,6.4,6.4-2.8,6.4-6.4,6.4Z"/>
        <path fill="currentColor" d="M30.6,36c-.4-3.9-1.3-9-2.9-11-1.1-1.4-2.3-2.2-3.5-2.6s-1.8-.6-6.3-.6-6.1.7-6.1.7c-1.2.4-2.4,1.2-3.4,2.6-1.7,1.9-2.6,7.1-3,10.9h25.2Z"/>
      </svg>
    {{/if}}
  </div>
{{/if}}
