<span class="{{pfv}}menu-toggle__icon
  {{setModifiers
    menu-toggle-icon--IsMirrorInlineRTL=menu-toggle-icon--IsMirrorInlineRTL
    menu-toggle-icon--modifier=menu-toggle-icon--modifier
  }}"
  {{#if menu-toggle-icon--attribute}}
    {{{menu-toggle-icon--attribute}}}
  {{/if}}>
  {{#if menu-toggle--icon}}
    {{#ifAny menu-toggle--IsSettings}}
      {{{pfIcon "rh-ui-settings-fill"}}}
    {{else}}
      {{#ifEquals menu-toggle--icon "cog"}}
        {{{pfIcon "rh-ui-settings-fill"}}}
      {{else ifEquals menu-toggle--icon "ellipsis-v"}}
        {{{pfIcon "rh-ui-ellipsis-vertical-fill"}}}
      {{else}}
        <i class="fas fa-{{menu-toggle--icon}}" aria-hidden="true"></i>
      {{/ifEquals}}
    {{/ifAny}}
  {{else if @partial-block}}
    {{> @partial-block}}
  {{/if}}
</span>
